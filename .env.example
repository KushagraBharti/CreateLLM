# Local Next.js app env template
# Copy this to `.env.local` for local development.

# Production Convex used everywhere
NEXT_PUBLIC_CONVEX_URL=https://glorious-moose-513.convex.cloud

# Local GitHub OAuth app
AUTH_SECRET=replace-with-local-auth-secret
AUTH_GITHUB_ID=replace-with-local-github-client-id
AUTH_GITHUB_SECRET=replace-with-local-github-client-secret

# Optional Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
